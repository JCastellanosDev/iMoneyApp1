{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/transacciones(.*)",
      "destination": "/backend/src/server.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/server.js"
    }
  ]
}