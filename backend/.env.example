# ── Configuración del backend FinFlow ──────────────────────────────
# Copia este archivo a `.env` y ajusta los valores.

# Puerto donde corre el API (la interfaz espera http://localhost:3000)
PORT=3000

# Secreto para firmar los JWT. CÁMBIALO en producción.
TOKEN_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Origen(es) permitido(s) por CORS, separados por coma. Usa * para permitir todos.
CORS_ORIGIN=*

# Clave de Gemini para los endpoints de IA (escaneo de ticket y coach).
# Si se deja vacía, esos endpoints responden con datos de demostración
# para que el backend siga siendo 100% funcional sin llaves.
GEMINI_API_KEY=

# ── Firebase / Firestore ────────────────────────────────────────────
# OPCIÓN A (recomendada para desarrollo): ruta al archivo JSON de
# cuenta de servicio descargado desde Firebase Console →
# Configuración del proyecto → Cuentas de servicio → Generar clave privada.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# OPCIÓN B: variables individuales (mejor para entornos cloud/CI).
# Deja FIREBASE_SERVICE_ACCOUNT_PATH vacío si usas esta opción.
# FIREBASE_PROJECT_ID=tu-proyecto-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
